#!/usr/bin/env bash
#
# commit-msg hook: Validates that commit messages contain a GitHub Issue number (#NNN).
# Merge commits (auto-generated by git) are excluded from this check.
#
# Setup: git config core.hooksPath .githooks

set -e

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits (auto-generated by git)
if echo "$COMMIT_MSG" | head -1 | grep -qE '^Merge '; then
  exit 0
fi

# Check for Issue number pattern (#NNN)
if ! echo "$COMMIT_MSG" | grep -qE '#[0-9]+'; then
  echo "ERROR: Commit message must contain a GitHub Issue number (e.g., #45)." >&2
  echo "       Your message: $(head -1 "$COMMIT_MSG_FILE")" >&2
  exit 1
fi
