{
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:dev.to)"
    ],
    "deny": [
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.config/gh/config.yml)",
      "Edit(./.git/**)",
      "Edit(./CLAUDE.md)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(gh repo delete*)",
      "Bash(gh secret *)",
      "Bash(gh api *)",
      "Bash(sudo *)",
      "Bash(rm *)",
      "Bash(wget *)",
      "Bash(chmod *)",
      "Bash(chown *)"
    ]
  }
}
